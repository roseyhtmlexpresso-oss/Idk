<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Connect to Device - Aleza</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #0a0a0a; color: white; text-align: center; margin: 0; padding: 20px; }
        .container { background: #1a1a1a; padding: 25px; border-radius: 20px; border: 1px solid #333; max-width: 500px; margin: auto; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        .version { color: #555; font-size: 11px; margin-bottom: 15px; letter-spacing: 1px; }
        .code-display { font-size: 42px; color: #00ffcc; font-family: monospace; margin: 20px 0; font-weight: bold; text-shadow: 0 0 10px rgba(0,255,204,0.3); }
        button { width: 100%; padding: 15px; font-size: 16px; font-weight: bold; cursor: pointer; border-radius: 10px; border: none; margin: 8px 0; transition: 0.2s; }
        .btn-blue { background: #3d5afe; color: white; }
        .btn-green { background: #28a745; color: white; }
        .btn-fs { background: #444; color: white; display: none; }
        input { width: 100%; padding: 15px; font-size: 18px; border-radius: 10px; border: 1px solid #444; background: #222; color: white; text-align: center; box-sizing: border-box; }
        video { width: 100%; border-radius: 12px; margin-top: 20px; display: none; background: #000; box-shadow: 0 5px 15px rgba(0,0,0,0.8); }
        hr { border: 0; border-top: 1px solid #333; margin: 25px 0; }
    </style>
</head>
<body>

    <div class="container">
        <div class="version">HTML5 | Version 0.1.2 | Created by Aleza</div>
        <h2 style="margin-top:0;">Connect to Device</h2>

        <div id="setup">
            <div id="codeShow" class="code-display">------</div>
            <button class="btn-blue" id="genBtn">Generate Broadcast Code</button>
            <button class="btn-green" id="startBtn" style="display:none;">Start Broadcast</button>
        </div>

        <hr>

        <div id="join">
            <input type="number" id="inputCode" placeholder="Enter 6-Digit Code">
            <button class="btn-blue" id="joinBtn">Connect to Device</button>
        </div>

        <video id="mainVideo" autoplay playsinline></video>
        <button class="btn-fs" id="fsBtn">Enter Fullscreen</button>
    </div>

    <script>
        const genBtn = document.getElementById('genBtn');
        const startBtn = document.getElementById('startBtn');
        const codeShow = document.getElementById('codeShow');
        const video = document.getElementById('mainVideo');
        const fsBtn = document.getElementById('fsBtn');
        const joinBtn = document.getElementById('joinBtn');

        // 1. Generate Random 6-Digit Code
        genBtn.onclick = () => {
            const randomCode = Math.floor(100000 + Math.random() * 900000);
            codeShow.innerText = randomCode;
            genBtn.style.display = 'none';
            startBtn.style.display = 'block';
        };

        // 2. Start Broadcast (Camera for Mobile Compatibility)
        startBtn.onclick = async () => {
            try {
                const stream = await navigator.mediaDevices.getUserMedia({
                    video: { facingMode: "environment" },
                    audio: true
                });
                video.srcObject = stream;
                video.style.display = 'block';
                fsBtn.style.display = 'block';
                alert("Broadcast Started! Point your camera at what you want to share.");
            } catch (err) {
                alert("Permission Error: Please allow camera access in your settings.");
                console.error(err);
            }
        };

        // 3. Connect/Join Logic (Simulated for this version)
        joinBtn.onclick = () => {
            const code = document.getElementById('inputCode').value;
            if(code.length === 6) {
                alert("Searching for Device [" + code + "]...");
                // In v0.1.2, this shows the local player as a preview
                video.style.display = 'block';
                fsBtn.style.display = 'block';
            } else {
                alert("Please enter a valid 6-digit code.");
            }
        };

        // 4. Fullscreen Logic (Works on Tablet & Phone)
        fsBtn.onclick = () => {
            if (video.requestFullscreen) {
                video.requestFullscreen();
            } else if (video.webkitEnterFullscreen) {
                video.webkitEnterFullscreen(); // Required for iOS/iPad
            }
        };
    </script>
</body>
</html>
